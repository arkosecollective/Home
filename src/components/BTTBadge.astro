---
interface Props {
	size?: 'sm' | 'md' | 'lg';
	className?: string;
}

const { size = 'md', className = '' } = Astro.props;

const sizes = {
	sm: 'w-24 h-24',
	md: 'w-48 h-48',
	lg: 'w-64 h-64'
};
---

<div class={`relative flex items-center justify-center ${sizes[size]} ${className} group`}>
	<!-- Outer Ring with Rotating Text -->
	<div class="absolute inset-0 animate-spin-slow group-hover:animate-spin-fast transition-all duration-1000">
		<svg viewBox="0 0 100 100" class="w-full h-full">
			<path id="textPath" d="M 50,50 m -37,0 a 37,37 0 1,1 74,0 a 37,37 0 1,1 -74,0" fill="none" />
			<text class="fill-stone-300 font-oswald font-bold text-[7.5px] uppercase tracking-[0.2em]">
				<textPath xlink:href="#textPath">
					BOARDROOM TO TRAILS — ARKOSE CERTIFIED — 
				</textPath>
			</text>
		</svg>
	</div>

	<!-- Inner Circle -->
	<div class="absolute inset-4 bg-stone-900 border border-stone-800 rounded-full flex items-center justify-center shadow-2xl shadow-arkose-red/10">
		<!-- Icon: Mountain transforms into blocks -->
		<svg viewBox="0 0 24 24" class="w-1/2 h-1/2 text-white" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
			<!-- Mountain Part -->
			<path d="M4 20l4-8 4 8" />
			<path d="M8 12l4-8 4 8" />
			<!-- Building Block Part -->
			<rect x="14" y="14" width="6" height="6" class="text-arkose-red" />
			<rect x="12" y="10" width="4" height="4" opacity="0.5" />
		</svg>
	</div>
</div>

<style>
	@keyframes spin-slow {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}
	@keyframes spin-fast {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}
	.animate-spin-slow {
		animation: spin-slow 12s linear infinite;
	}
	.group:hover .animate-spin-fast {
		animation: spin-fast 6s linear infinite;
	}
</style>

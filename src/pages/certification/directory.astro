---
import Layout from '../../layouts/Layout.astro';
import certifiedCompanies from '../../data/certified_companies.json';
import BTTBadge from '../../components/BTTBadge.astro';
---

<Layout title="BTT Certified Directory | Arkose Collective">
	<section class="pt-48 pb-24 px-8 bg-black min-h-screen">
		<div class="max-w-7xl mx-auto">
			<div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
				<div class="max-w-2xl">
					<h1 class="text-5xl md:text-6xl font-oswald font-bold uppercase tracking-tighter mb-4">
						The <span class="text-arkose-red">Directory</span>
					</h1>
					<p class="text-stone-400 font-inter font-light text-lg">
						Leaders invested in the bedrock of the Pikes Peak region. These companies have met the rigorous Boardroom to Trails (BTT) certification standards.
					</p>
				</div>
				<a href="/certification/apply" class="bg-arkose-red text-white font-oswald uppercase tracking-widest px-10 py-4 hover:bg-white hover:text-black transition-all">
					Get Certified
				</a>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{certifiedCompanies.map((company) => (
					<div class="bg-stone-900/30 border border-stone-800 p-8 hover:border-arkose-red transition-all group relative overflow-hidden">
						<!-- Background Badge Accent -->
						<div class="absolute -right-12 -top-12 opacity-5 grayscale group-hover:grayscale-0 group-hover:opacity-10 transition-all">
							<BTTBadge size="md" />
						</div>

						<span class="text-arkose-red font-oswald uppercase text-[10px] tracking-widest block mb-1">{company.industry}</span>
						<h3 class="text-2xl font-oswald font-bold uppercase tracking-tight mb-4 group-hover:text-white transition-colors">{company.company_name}</h3>
						
						<div class="space-y-4 border-t border-stone-800 pt-6">
							<div class="flex justify-between items-center text-xs">
								<span class="text-stone-500 uppercase tracking-widest">Location Score</span>
								<span class="text-white font-bold">{company.location_score}/10</span>
							</div>
							<div class="space-y-1">
								<span class="text-[10px] text-stone-600 uppercase tracking-widest">Partner</span>
								<p class="text-xs text-stone-300 italic">"{company.non_profit_partner}"</p>
							</div>
							<div class="space-y-1">
								<span class="text-[10px] text-stone-600 uppercase tracking-widest">Engagement Policy</span>
								<p class="text-xs text-stone-300 line-clamp-2">{company.employee_engagement_policy}</p>
							</div>
						</div>

						<a href={company.website} target="_blank" class="mt-8 inline-block text-[10px] font-oswald uppercase tracking-[0.2em] text-arkose-red border-b border-arkose-red/30 pb-1 hover:border-arkose-red transition-all">
							Visit Website
						</a>
					</div>
				))}
			</div>
		</div>
	</section>
</Layout>

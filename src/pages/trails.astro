---
import Layout from '../layouts/Layout.astro';
import TrailPlanner from '../components/TrailPlanner.astro';
import trailsData from '../data/trails.json';
import partnersData from '../data/partners.json';

// Helper to find partners for a specific trail
const getPartnersForTrail = (trailId: string) => {
	return partnersData.filter(partner => partner.trail_pairing.includes(trailId));
};

const getDifficultyColor = (difficulty: string) => {
	const lowerDiff = difficulty.toLowerCase();
	if (lowerDiff.includes('green')) return 'text-emerald-500';
	if (lowerDiff.includes('blue')) return 'text-blue-500';
	if (lowerDiff.includes('black')) return 'text-white underline decoration-arkose-red';
	return 'text-stone-500';
};

const stayPartners = partnersData.filter(p => p.category === 'Stay');
const eatPartners = partnersData.filter(p => p.category === 'Eat');
const seePartners = partnersData.filter(p => p.category === 'See');
---

<Layout title="Adventure Planner | Arkose">
	<section class="pt-32 pb-16 px-8 bg-black min-h-screen">
		<div class="max-w-7xl mx-auto">
			<div class="mb-12 border-b border-stone-800 pb-10">
				<h1 class="text-5xl md:text-7xl font-oswald font-bold tracking-tighter uppercase mb-4">
					Adventure <span class="text-arkose-red">Planner</span>
				</h1>
				<p class="text-stone-400 text-lg max-w-2xl font-light">
					The foundational infrastructure for your next Pikes Peak epic. Filter the bedrock of the region.
				</p>
			</div>

			<!-- Adventure Suggestions Menu -->
			<TrailPlanner />

			<!-- Quick Filters (Visual Only for Prototype) -->
			<div class="flex flex-wrap gap-4 mb-16">
				<button class="bg-white text-black font-oswald uppercase tracking-widest text-xs px-6 py-3 hover:bg-arkose-red hover:text-white transition-colors">All Categories</button>
				<button class="border border-stone-700 text-white font-oswald uppercase tracking-widest text-xs px-6 py-3 hover:border-white transition-colors">Bike Accessible</button>
				<button class="border border-stone-700 text-white font-oswald uppercase tracking-widest text-xs px-6 py-3 hover:border-white transition-colors">RTP Segments</button>
			</div>

			<!-- 4-Column Ecosystem Grid -->
			<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-8">
				
				<!-- 01: Trails -->
				<div class="space-y-8">
					<h2 class="text-2xl font-oswald font-bold uppercase tracking-tighter flex items-center gap-3 border-b border-stone-800 pb-4">
						<span class="text-arkose-red">01</span> Trails
					</h2>
					<div class="space-y-4">
						{trailsData.map(trail => (
							<div class="bg-stone-900/40 border border-stone-800 p-6 hover:border-stone-600 transition-all group">
								<div class="flex justify-between items-start mb-2">
									<h3 class="font-oswald font-bold uppercase tracking-tight text-lg group-hover:text-arkose-red transition-colors">{trail.name}</h3>
								</div>
								<p class="text-stone-500 text-xs font-inter leading-snug mb-4 line-clamp-2">{trail.description}</p>
								<div class="flex flex-wrap gap-3 text-[10px] font-oswald uppercase tracking-widest">
									<span class={getDifficultyColor(trail.difficulty)}>{trail.difficulty}</span>
									<span class="text-stone-600">Index: {trail.fun_index}</span>
								</div>
							</div>
						))}
					</div>
				</div>

				<!-- 02: Where to Stay -->
				<div class="space-y-8">
					<h2 class="text-2xl font-oswald font-bold uppercase tracking-tighter flex items-center gap-3 border-b border-stone-800 pb-4">
						<span class="text-arkose-red">02</span> Stay
					</h2>
					<div class="space-y-4">
						{stayPartners.map(partner => (
							<a href={partner.url} class="block bg-stone-900/40 border border-stone-800 p-6 hover:border-arkose-red transition-all group">
								<h3 class="font-oswald font-bold uppercase tracking-tight text-lg mb-1 group-hover:text-arkose-red transition-colors">{partner.name}</h3>
								<p class="text-stone-500 text-xs font-inter leading-snug mb-4">{partner.description}</p>
								<span class="text-[10px] font-oswald uppercase tracking-[0.2em] text-arkose-red border-b border-arkose-red/30 pb-1">Basecamp</span>
							</a>
						))}
					</div>
				</div>

				<!-- 03: Where to Eat -->
				<div class="space-y-8">
					<h2 class="text-2xl font-oswald font-bold uppercase tracking-tighter flex items-center gap-3 border-b border-stone-800 pb-4">
						<span class="text-arkose-red">03</span> Eat
					</h2>
					<div class="space-y-4">
						{eatPartners.map(partner => (
							<a href={partner.url} target="_blank" class="block bg-stone-900/40 border border-stone-800 p-6 hover:border-arkose-red transition-all group">
								<h3 class="font-oswald font-bold uppercase tracking-tight text-lg mb-1 group-hover:text-arkose-red transition-colors">{partner.name}</h3>
								<p class="text-stone-500 text-xs font-inter leading-snug mb-4">{partner.description}</p>
								<span class="text-[10px] font-oswald uppercase tracking-[0.2em] text-white border-b border-white/30 pb-1 italic">Fuel</span>
							</a>
						))}
					</div>
				</div>

				<!-- 04: What to See -->
				<div class="space-y-8">
					<h2 class="text-2xl font-oswald font-bold uppercase tracking-tighter flex items-center gap-3 border-b border-stone-800 pb-4">
						<span class="text-arkose-red">04</span> See
					</h2>
					<div class="space-y-4">
						{seePartners.map(partner => (
							<a href={partner.url} target="_blank" class="block bg-stone-900/40 border border-stone-800 p-6 hover:border-arkose-red transition-all group">
								<h3 class="font-oswald font-bold uppercase tracking-tight text-lg mb-1 group-hover:text-arkose-red transition-colors">{partner.name}</h3>
								<p class="text-stone-500 text-xs font-inter leading-snug mb-4">{partner.description}</p>
								<span class="text-[10px] font-oswald uppercase tracking-[0.2em] text-stone-400 border-b border-stone-400/30 pb-1">Landmark</span>
							</a>
						))}
					</div>
				</div>

			</div>
		</div>
	</section>
</Layout>
